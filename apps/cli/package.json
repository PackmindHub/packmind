{
  "name": "@packmind/cli",
  "version": "0.31.0-next",
  "description": "A command-line interface for Packmind linting and code quality checks",
  "private": false,
  "bin": {
    "packmind-cli": "./main.cjs",
    "packmind": "./main.cjs"
  },
  "main": "./main.cjs",
  "files": [
    "main.cjs",
    "*.wasm",
    "stubs",
    "CHANGELOG.MD"
  ],
  "keywords": [
    "packmind",
    "linting",
    "code-quality",
    "cli",
    "static-analysis"
  ],
  "author": "Packmind",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PackmindHub/packmind.git",
    "directory": "apps/cli"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "packmind-cli": "ts-node --project tsconfig.app.json src/main.ts"
  },
  "dependencies": {
    "chalk": "^5.6.0",
    "cmd-ts": "^0.14.3",
    "diff": "^8.0.3",
    "dotenv": "^16",
    "inquirer": "^13.0.2",
    "log-update": "^8.0.0",
    "minimatch": "^10",
    "open": "^11.0.0",
    "semver": "^7.7.4",
    "slug": "^11.0.0",
    "undici": "^7.28.0",
    "which": "^4.0.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/which": "^3.0.4"
  }
}
