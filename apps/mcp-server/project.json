{
  "name": "mcp-server",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/mcp-server/src",
  "projectType": "application",
  "tags": ["env:node"],
  "targets": {
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "apps/mcp-server/jest.config.ts"
      },
      "cache": true
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit --project apps/mcp-server/tsconfig.app.json"
      }
    },
    "build": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "dependsOn": [],
      "options": {
        "platform": "node",
        "outputPath": "dist/apps/mcp-server",
        "format": ["cjs"],
        "bundle": true,
        "main": "apps/mcp-server/src/main.ts",
        "tsConfig": "apps/mcp-server/tsconfig.app.json",
        "assets": [
          "apps/mcp-server/src/assets"
        ],
        "generatePackageJson": true,
        "esbuildOptions": {
          "sourcemap": true,
          "outExtension": {
            ".js": ".js"
          },
          "external": ["class-validator", "class-transformer"]
        }
      },
      "configurations": {
        "development": {
          "watch": true
        },
        "production": {
          "assets": [
            "apps/mcp-server/src/assets",
            {
              "input": "packages/linter-ast/res",
              "glob": "*.wasm",
              "output": "."
            }
          ],
          "esbuildOptions": {
            "sourcemap": false,
            "outExtension": {
              ".js": ".js"
            },
            "external": ["class-validator", "class-transformer"]
          }
        }
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "defaultConfiguration": "development",
      "options": {
        "parallel": true,
        "commands": [
          "nx run mcp-server:build:development --skip-nx-cache",
          "sh -lc 'rm -f dist/apps/mcp-server/main.js; mkdir -p dist/apps/mcp-server; while [ ! -f dist/apps/mcp-server/main.js ]; do sleep 0.2; done; npx nodemon --watch dist/apps/mcp-server --ext js,json --legacy-watch --polling-interval 500 dist/apps/mcp-server/main.js'"
        ]
      },
      "configurations": {
        "development": {},
        "production": {
          "parallel": false,
          "commands": [
            "nx run mcp-server:build:production --skip-nx-cache",
            "node dist/apps/mcp-server/main.js"
          ]
        }
      }
    }
  }
}
