FROM node:26.3.1-alpine3.23@sha256:bead114a5f13c3f193e6278d28bc10a3e0cd464cb1c764c1abac79b1cc15f64f

ENV NODE_ENV=production

# Update OpenSSL and install required system dependencies
RUN apk update && \
    apk add --no-cache \
        openssl=3.5.7-r0 \
        bash=5.3.3-r1 \
        ca-certificates=20260413-r0 && \
    rm -rf /sbin/apk /etc/apk /lib/apk /usr/share/apk /var/cache/apk

# Use the existing node user from the base image
USER node

# Set working directory
WORKDIR /app

# Activate pnpm via corepack in a shared cache so both root and node see the same binary
# (otherwise corepack prepare runs as root and pnpm install re-downloads under node's home)
USER root
ENV COREPACK_HOME=/usr/local/share/node/corepack
RUN corepack enable && corepack prepare pnpm@11.5.0 --activate && \
    chmod -R a+rX "$COREPACK_HOME"
USER node

# Copy package files with proper ownership
COPY --chown=node:node dist/apps/mcp-server/package.json dist/apps/mcp-server/pnpm-lock.yaml ./

# Install production dependencies (the lockfile pins transitive versions for reproducible builds)
RUN pnpm install --prod --ignore-scripts && pnpm store prune

# Copy the built application with proper ownership
COPY --chown=node:node dist/apps/mcp-server/ ./

# Copy base tree-sitter WASM files to /app/ directory for runtime initialization
COPY --chown=node:node dist/apps/mcp-server/tree-sitter*.wasm ./

# Remove npm/pnpm and their global node_modules to eliminate vulnerabilities
USER root
RUN rm -rf /usr/local/lib/node_modules/npm /usr/local/lib/node_modules/corepack && \
    rm -f /usr/local/bin/npm /usr/local/bin/npx /usr/local/bin/pnpm /usr/local/bin/pnpx /usr/local/bin/corepack
USER node

# Expose port
EXPOSE 3001

# Start the application
ENTRYPOINT ["node", "main.js"]
