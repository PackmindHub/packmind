FROM node:25.8.1-alpine@sha256:5209bcaca9836eb3448b650396213dbe9d9a34d31840c2ae1f206cb2986a8543

ENV NODE_ENV=production

# Install required system dependencies with pinned versions
RUN apk add --no-cache \
        openssl=3.5.5-r0 \
        bash=5.2.37-r0 \
        ca-certificates=20250911-r0

# Use the existing node user from the base image
USER node

# Set working directory
WORKDIR /app

# Copy package files with proper ownership
COPY --chown=node:node dist/apps/mcp-server/package.json dist/apps/mcp-server/package-lock.json ./

# Install production dependencies
RUN npm install --omit=dev --ignore-scripts && npm cache clean --force

# Copy the built application with proper ownership
COPY --chown=node:node dist/apps/mcp-server/ ./

# Copy base tree-sitter WASM files to /app/ directory for runtime initialization
COPY --chown=node:node dist/apps/mcp-server/tree-sitter*.wasm ./

# Remove npm, npx, and apk to eliminate vulnerabilities and reduce attack surface
USER root
RUN rm -rf /usr/local/lib/node_modules/npm && \
    rm -f /usr/local/bin/npm /usr/local/bin/npx && \
    rm -rf /sbin/apk /etc/apk /lib/apk /usr/share/apk /var/cache/apk
USER node

# Expose port
EXPOSE 3001

# Start the application
ENTRYPOINT ["node", "main.js"]
