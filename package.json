{
  "name": "packmind",
  "version": "1.15.1",
  "private": true,
  "engines": {
    "node": ">=24.13.0",
    "pnpm": ">=11.0.0 <12.0.0"
  },
  "packageManager": "pnpm@11.5.0",
  "scripts": {
    "build": "NODE_OPTIONS='--max-old-space-size=16384' nx run-many -t build",
    "chakra:typegen": "pnpm --filter ./packages/ui exec chakra typegen ./src/lib/theme/theme.ts",
    "e2e": "PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=false pnpm exec playwright test --config apps/e2e-tests/playwright.config.ts",
    "husky": "husky",
    "lint": "nx run-many -t lint",
    "lint:staged": "nx affected:lint --parallel --uncommitted",
    "packmind-cli:build": "nx run packmind-cli:build --skip-nx-cache",
    "packmind-cli:lint": "pnpm packmind-cli:build && sh scripts/install-dist-cli-deps.sh && node dist/apps/cli/main.cjs lint .",
    "prepare": "node scripts/prepare.mjs",
    "prettier:check": "prettier -c .",
    "prettier:write": "prettier -w .",
    "quality-gate": "pnpm typecheck:frontend && pnpm test:staged && pnpm lint:staged && pnpm build",
    "withEnv": "bash -c 'set -a; [ -f .env ] && source .env; set +a; eval \"$@\"' --",
    "test": "PACKMIND_LOG_LEVEL=silent pnpm withEnv \"NODE_OPTIONS='--max-old-space-size=16384 --no-experimental-strip-types' nx run-many -t test --exclude=cli-e2e-tests --parallel=\\${NX_PARALLEL_TESTS:-3}\"",
    "test:staged": "PACKMIND_LOG_LEVEL=silent pnpm withEnv \"NODE_OPTIONS='--max-old-space-size=16384 --no-experimental-strip-types' nx affected:test --parallel=\\${NX_PARALLEL_TESTS:-3}\"",
    "test:memory-profile": "./scripts/test-memory-profile.sh",
    "typecheck:frontend": "nx run frontend:typecheck"
  },
